# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ezlaunch
POSTGRES_USER=ezl
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Node app ──────────────────────────────────────────────────────────────────
NODE_PORT=3000
NODE_ENV=development

# ── Python app ────────────────────────────────────────────────────────────────
PYTHON_PORT=8000

# ── App ───────────────────────────────────────────────────────────────────────
# APP_SECRET is REQUIRED — the app refuses to start without a strong unique value
# (placeholders like this one are rejected). Generate: `openssl rand -hex 32`
APP_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173

# ── Auth rate limits (optional — sane defaults applied if unset) ───────────────
# Per-IP / per-account throttling on auth endpoints (C2). Counts per window.
# AUTH_LOGIN_IP_MAX=10        # /login per IP   (15 min)
# AUTH_LOGIN_EMAIL_MAX=5      # /login per email(15 min)
# AUTH_REGISTER_IP_MAX=5      # /register per IP(60 min)
# AUTH_FORGOT_IP_MAX=5        # /forgot per IP  (60 min)
# AUTH_FORGOT_EMAIL_MAX=3     # /forgot per email(60 min)
# AUTH_REFRESH_IP_MAX=30      # /refresh per IP (15 min)

# ── Initial admin (optional) ──────────────────────────────────────────────────
# If both are set, node-app provisions this admin on boot (idempotent: created
# once, then only promoted to admin if the account exists without that role).
# Leave empty to skip. Use a strong password — staging/prod are reachable.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── SMTP (optional — omit for dev mode, token logged instead) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ezlaunch.app
